# Frontend Configuration
VITE_API_BASE_URL=http://localhost:4002
VITE_WS_BASE_URL=ws://localhost:4002

# Backend Configuration
PORT=4002

# Orchestration / Agent Stack (Multi-LLM Support)
# Choose your active provider: local, remote, openai, gemini, openrouter, anthropic, gemini-cli, opencode-cli
ACTIVE_LLM_PROVIDER=local

# 1. Local LM Studio (Laptop)
LOCAL_LLM_API_BASE=http://localhost:1234/v1
LOCAL_LLM_MODEL=local-model
LOCAL_OPENAI_API_KEY=lm-studio

# 2. Remote Ollama (Cloudflare Tunnel)
REMOTE_LLM_API_BASE=https://your-tunnel.trycloudflare.com/v1
REMOTE_LLM_MODEL=llama3
REMOTE_OPENAI_API_KEY=ollama

# 3. Standard OpenAI
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o

# 4. Google Gemini API
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-1.5-pro

# 5. OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# 6. Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# 7. Local CLI Models (Optional)
# Set these to 'true' if you have the 'gemini' or 'opencode' CLIs installed
USE_GEMINI_CLI=false
USE_OPENCODE_CLI=false

# OpenCode CLI — how many 2-second poll attempts before giving up on a task
# 150 = 5 minutes (default). Increase for large implementations.
OPENCODE_TIMEOUT_ATTEMPTS=150

# Memory Storage
MEMORY_DB_PATH=./server/agent-stack/memory/store.db

# Security (Debug Endpoints)
# If set, debug endpoints (/debug/*) require this key in the 'x-debug-key' header.
# If NOT set, debug endpoints are restricted to loopback (localhost) only.
# DEBUG_API_KEY=your-secure-debug-key
